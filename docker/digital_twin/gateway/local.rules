# SSH brute-force detection
alert tcp any any -> $HOME_NET 22 (msg:"ET SCAN SSH Brute Force Login Attempt"; \
    flow:to_server,established; threshold:type both,track by_src,count 5,seconds 60; \
    classtype:attempted-recon; sid:2006546; rev:3;)

# SQL injection detection
alert tcp any any -> $HOME_NET 80 (msg:"ET EXPLOIT Possible SQL Injection Attempt (UNION SELECT)"; \
    flow:to_server,established; content:"UNION"; nocase; content:"SELECT"; nocase; \
    classtype:attempted-admin; sid:2014473; rev:3;)

alert tcp any any -> $HOME_NET 80 (msg:"ET EXPLOIT Possible SQL Injection Attempt (OR 1=1)"; \
    flow:to_server,established; content:"OR"; nocase; content:"1"; content:"="; content:"1"; \
    classtype:attempted-admin; sid:2014474; rev:1;)
